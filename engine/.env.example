# Database
DB_TYPE=sqlite
SQLITE_PATH=./data/zephyr.db

# MySQL (if DB_TYPE=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=zephyr
MYSQL_USER=zephyr
MYSQL_PASSWORD=

# Engine HTTP server (serves both ingest and API)
ENGINE_PORT=8080
ENGINE_HOST=0.0.0.0

# Ingest: push receiver (WU / Ecowitt)
INGEST_PUSH_ENABLED=true

# Ingest: GW1000 LAN API poller
INGEST_POLL_ENABLED=false
GW_HOST=192.168.1.100
GW_PORT=45000
POLL_INTERVAL_SECONDS=60

# Station metadata
STATION_NAME=My Weather Station
STATION_LAT=-33.8688
STATION_LON=151.2093
STATION_ALTITUDE_M=50
STATION_TIMEZONE=Australia/Sydney
# JSON array of embedded pages: [{"label":"Radar","url":"https://...","height":400}]
STATION_EXTRAS_JSON=[]

# weewx migration (engine/scripts/migrate-weewx.ts)
WEEWX_MYSQL_HOST=localhost
WEEWX_MYSQL_PORT=3306
WEEWX_MYSQL_USER=weewx
WEEWX_MYSQL_PASSWORD=
WEEWX_MYSQL_DATABASE=weewx
