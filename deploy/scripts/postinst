#!/bin/bash
# Debian postinst script for the zephyr package.
# Called by dpkg after files are installed.
#
# Calling conventions:
#   postinst configure <most-recently-configured-version>  — fresh install or upgrade
#   postinst abort-upgrade <new-version>
#   postinst abort-remove
#   postinst abort-deconfigure
set -e

case "$1" in
  configure)
    # ── 1. System user ────────────────────────────────────────────────────────────
    if ! getent passwd zephyr > /dev/null 2>&1; then
      useradd \
        --system \
        --no-create-home \
        --home-dir /var/lib/zephyr \
        --shell /sbin/nologin \
        --comment "Zephyr Weather Station" \
        zephyr
    fi

    # ── 2. Data directory ───────────────────────────────────────────────────────
    mkdir -p /var/lib/zephyr
    chown zephyr:zephyr /var/lib/zephyr
    chmod 0750 /var/lib/zephyr

    # ── 3. Config directory ─────────────────────────────────────────────────────
    # Lock down /etc/zephyr so only root and the zephyr group can read it.
    # zephyr.toml may contain credentials (DB passwords, API keys).
    if [ -d /etc/zephyr ]; then
      chown root:zephyr /etc/zephyr
      chmod 0750 /etc/zephyr
      # Example file contains no secrets; keep it world-readable.
      chmod 0644 /etc/zephyr/*.example 2>/dev/null || true
    fi

    # ── 4. Bootstrap zephyr.toml from example if not present ────────────────────
    # On first install, copy the example config into place so the daemons can
    # start.  On upgrades the existing file is left untouched (noreplace).
    if [ ! -f /etc/zephyr/zephyr.toml ]; then
      cp /etc/zephyr/zephyr.toml.example /etc/zephyr/zephyr.toml
      chown root:zephyr /etc/zephyr/zephyr.toml
      chmod 0640 /etc/zephyr/zephyr.toml
      echo "Zephyr: created /etc/zephyr/zephyr.toml from example — edit before starting."
    fi

    # ── 5. systemd ──────────────────────────────────────────────────────────────────
    # Reload the unit database so the new unit files are visible.
    systemctl daemon-reload 2>/dev/null || true

    # Enable zephyr-engine and zephyr-web (creates WantedBy symlinks under
    # zephyr.target.wants/), then enable zephyr.target itself (registers it
    # under multi-user.target.wants/ so it starts at boot).
    systemctl enable \
      zephyr-engine.service \
      zephyr-web.service \
      zephyr.target \
      2>/dev/null || true

    # Start the stack.  The || true ensures the package install succeeds even
    # when running inside a container, chroot, or cloud-init environment where
    # systemd is not the init process.
    systemctl start zephyr.target 2>/dev/null || true
    ;;

  abort-upgrade|abort-remove|abort-deconfigure)
    ;;
esac

exit 0
