# ==============================================================================
# Zephyr Web — Daemon Configuration
# Production path: /etc/zephyr/web.env
#
# This file is read by the zephyr-web systemd unit via EnvironmentFile=.
#
# Usage:
#   sudo cp deploy/etc/web.env.example /etc/zephyr/web.env
#   sudo chown root:zephyr /etc/zephyr/web.env
#   sudo chmod 640 /etc/zephyr/web.env
#   sudo systemctl restart zephyr-web
# ==============================================================================

# ------------------------------------------------------------------------------
# HTTP Server
# ------------------------------------------------------------------------------

# Port the web UI server listens on.
#
# This variable is named PORT (rather than WEB_PORT) because the Fresh v2
# compiled-entry binary reads PORT natively.  The `deno run server.ts` path
# (start:prod task) also reads PORT as the primary variable, with WEB_PORT
# as a legacy fallback for older local .env files.
#
# If you are running a reverse proxy (nginx, Caddy, Traefik) in front of
# zephyr-web, this is the upstream port you proxy to.  The public-facing
# port is whatever you configure in your proxy.
# Default: 8081
PORT=8081

# IP address to bind the web server to.
# 0.0.0.0 listens on all interfaces.  If you are behind a reverse proxy on
# the same host you can restrict to 127.0.0.1.
# Default: 0.0.0.0
HOSTNAME=0.0.0.0

# ------------------------------------------------------------------------------
# Engine Connection
# ------------------------------------------------------------------------------

# Base URL of the zephyr-engine HTTP API.
# Server-side route handlers use this URL directly for SSR data fetches.
# Browser-side islands always call /api/* (same-origin), which the web server
# proxies to this address, so this variable is server-only.
#
# Single-host deployment:  use http://localhost:ENGINE_PORT
# Multi-host deployment:   use the engine's LAN address or DNS name.
#
# Must NOT have a trailing slash.
# Default: http://localhost:8080
WEB_ENGINE_URL=http://localhost:8080
