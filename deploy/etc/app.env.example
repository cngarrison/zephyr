# ==============================================================================
# Zephyr — Application / Station Configuration
# Production path: /etc/zephyr/app.env
#
# Loaded by BOTH zephyr-engine and zephyr-web systemd units.
#
# ┌─ Migration note ─────────────────────────────────────────────────────────┐
# │  This file is a transitional format.  Issue zephyr-20e will replace      │
# │  these environment variables with a structured TOML config file           │
# │  (/etc/zephyr/zephyr.toml) that natively supports multi-station arrays,  │
# │  typed values, and inline documentation.                                  │
# │                                                                            │
# │  Variable names defined here are kept stable so that the migration from   │
# │  env → TOML can be performed without changing running service behaviour.  │
# └──────────────────────────────────────────────────────────────────────────┘
#
# Usage:
#   sudo cp deploy/etc/app.env.example /etc/zephyr/app.env
#   sudo chown root:zephyr /etc/zephyr/app.env
#   sudo chmod 644 /etc/zephyr/app.env   # no secrets in this file
#   sudo systemctl restart zephyr.target
# ==============================================================================

# ------------------------------------------------------------------------------
# Station Identity
# ------------------------------------------------------------------------------

# Human-readable name for this weather station.
# Shown in the web UI header and used internally as the station_id in the
# observations database.  Changing this after data has been collected will
# cause existing records to appear under the old name — a migration will be
# needed (see zephyr-20e).
STATION_NAME=My Weather Station

# Geographic coordinates (decimal degrees, WGS84).
# Used for almanac calculations: sunrise/sunset times, moon phase, solar
# elevation.  Positive = North / East; negative = South / West.
STATION_LAT=51.5074
STATION_LON=-0.1278

# Station elevation above mean sea level, in metres.
# Used for display and may be used for pressure correction in future.
STATION_ALTITUDE_M=10

# IANA timezone identifier for the station's local time.
# Controls daily boundary calculations (midnight roll-overs, "today" stats,
# aggregate bucketing, etc.).  Must match the IANA tz database exactly.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: America/New_York  Europe/London  Australia/Sydney  UTC
STATION_TIMEZONE=Europe/London

# ------------------------------------------------------------------------------
# Station Extras (optional embedded iframes)
# ------------------------------------------------------------------------------

# JSON array of embed objects to display in the web UI.
# Each object must have "label" (string) and "url" (string) fields;
# "height" (number, pixels) is optional and defaults to a sensible value.
#
# Example (single entry, all on one line — systemd does not support multiline):
#   STATION_EXTRAS_JSON=[{"label":"Radar","url":"https://example.com/radar","height":400}]
#
# Leave empty or unset for no embeds.
# Default: [] (no extras)
# STATION_EXTRAS_JSON=[]
