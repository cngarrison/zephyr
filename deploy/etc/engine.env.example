# ==============================================================================
# Zephyr Engine — Daemon Configuration
# Production path: /etc/zephyr/engine.env
#
# This file is read by the zephyr-engine systemd unit via EnvironmentFile=.
# It covers daemon-level concerns: HTTP binding, storage backend, and ingest
# driver settings.  Station identity lives in app.env (loaded separately).
#
# Usage:
#   sudo cp deploy/etc/engine.env.example /etc/zephyr/engine.env
#   sudo chown root:zephyr /etc/zephyr/engine.env
#   sudo chmod 640 /etc/zephyr/engine.env   # keep credentials out of world-read
#   sudo systemctl restart zephyr-engine
# ==============================================================================

# ------------------------------------------------------------------------------
# HTTP Server
# ------------------------------------------------------------------------------

# Port the engine listens on for both ingest (/ingest/*) and API (/api/*)
# requests.  The web daemon proxies /api/* to this address, so if you change
# this you must also update WEB_ENGINE_URL in web.env.
# Default: 8080
ENGINE_PORT=8080

# IP address to bind the engine HTTP server to.
# 0.0.0.0 listens on all interfaces.  On a single-host deployment you can
# restrict to 127.0.0.1 so the engine is not reachable from the network
# directly (the web daemon proxies all public-facing API traffic).
# Default: 0.0.0.0
ENGINE_HOST=0.0.0.0

# ------------------------------------------------------------------------------
# Storage Backend
# ------------------------------------------------------------------------------

# Storage provider to activate.  Supported values: sqlite | mysql
# Default: sqlite
DB_PROVIDER=sqlite

# -- SQLite -------------------------------------------------------------------
# Used when DB_PROVIDER=sqlite.

# Absolute path to the SQLite database file.
# The parent directory must exist and be writable by the zephyr system user.
# The engine creates the file on first start and runs forward-only migrations
# automatically — no manual schema setup required.
# Default (production): /var/lib/zephyr/zephyr.db
SQLITE_PATH=/var/lib/zephyr/zephyr.db

# -- MySQL / MariaDB ----------------------------------------------------------
# Used when DB_PROVIDER=mysql.  Uncomment and fill in if using MySQL.
# The zephyr user should have CREATE, ALTER, INSERT, UPDATE, SELECT privileges
# on the target database so migrations can run on first start.

# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=zephyr
# MYSQL_PASSWORD=changeme
# MYSQL_DATABASE=zephyr

# ------------------------------------------------------------------------------
# Ingest: Push (WU / Ecowitt)
# ------------------------------------------------------------------------------

# Enable the HTTP push ingest endpoints (/ingest/wu and /ingest/ecowitt).
# Set to false only if you are exclusively using the LAN poller below.
# Default: true
INGEST_PUSH_ENABLED=true

# Write raw ingest POST/GET params to disk for debugging.
# Useful when adding a new device or investigating normalisation issues.
# Creates files under the engine working directory; do not leave enabled in
# production.
# Default: false
INGEST_DEBUG_DUMP=false

# ------------------------------------------------------------------------------
# Ingest: GW1000 / GW1200 LAN API Poller (optional)
# ------------------------------------------------------------------------------

# Enable the LAN poller that contacts the GW-series base station directly.
# Only needed if your device does not support push (WU/Ecowitt) mode, or if
# you want to supplement push data with direct polling.
# Default: false
INGEST_POLL_ENABLED=false

# Hostname or IP address of the GW-series device on your local network.
# Required when INGEST_POLL_ENABLED=true.
# Default: 192.168.1.100
# GW_HOST=192.168.1.100

# Port the GW device's local API listens on.  Usually does not need changing.
# Default: 45000
# GW_PORT=45000

# How often (in seconds) to poll the device for a new reading.
# Default: 60
# POLL_INTERVAL_SECONDS=60
